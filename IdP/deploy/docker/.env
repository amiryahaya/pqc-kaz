# =============================================================================
# PQC Identity Platform - Docker Environment Configuration
# =============================================================================
# Copy this file to .env and adjust values as needed
# cp .env.example .env

# =============================================================================
# PostgreSQL Configuration
# =============================================================================
POSTGRES_USER=idp
POSTGRES_PASSWORD=idp_dev_password
POSTGRES_DB=idp_platform
POSTGRES_PORT=5432

# =============================================================================
# Redis Configuration
# =============================================================================
REDIS_PORT=6379

# =============================================================================
# SoftHSM Configuration
# =============================================================================
HSM_TOKEN_LABEL=idp-dev-token
HSM_SO_PIN=12345678
HSM_USER_PIN=87654321

# =============================================================================
# Observability - Jaeger (Tracing)
# =============================================================================
JAEGER_UI_PORT=16686
JAEGER_OTLP_GRPC_PORT=4317
JAEGER_OTLP_HTTP_PORT=4318

# =============================================================================
# Observability - Prometheus (Metrics)
# =============================================================================
PROMETHEUS_PORT=9090

# =============================================================================
# Observability - Grafana (Dashboards)
# =============================================================================
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# =============================================================================
# Observability - Seq (Logging)
# =============================================================================
SEQ_UI_PORT=8081
SEQ_INGEST_PORT=5341
# Optional: Set admin password hash (generate with: echo 'password' | docker run --rm -i datalust/seq config hash)
# SEQ_ADMIN_PASSWORD_HASH=

# =============================================================================
# Application Configuration (for .NET API)
# =============================================================================
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://+:5000

# Connection Strings (used by .NET app)
ConnectionStrings__Default=Host=localhost;Port=5432;Database=idp_platform;Username=idp;Password=idp_dev_password
ConnectionStrings__Redis=localhost:6379

# OpenTelemetry
Otlp__Endpoint=http://localhost:4317
Seq__Url=http://localhost:5341
